# ========================================
# Environment Variables - Secret Settings
# ========================================
# Yeh file apni machine ke hisaab se update karo
# Is file ko GitHub pe kabhi upload mat karna!

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://neondb_owner:npg_YaF3NCpumvq9@ep-holy-surf-atafx6f2.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT Secret Key - Koi bhi random string likhdo (jitni lambi utni better)
SECRET_KEY=ecommerce-secret-key-2024-change-in-production

# JWT Algorithm
ALGORITHM=HS256

# Token Expiry - Kitne minutes mein token expire ho (60 min = 1 ghanta)
ACCESS_TOKEN_EXPIRE_MINUTES=60
